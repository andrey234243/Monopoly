{
  "entities": {
    "Room": {
      "title": "Room",
      "description": "A multiplayer game room",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "hostId": { "type": "string" },
        "gameState": { "type": "string", "description": "Serialized game state" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "name", "hostId", "gameState", "createdAt", "updatedAt"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Player's statistics across games",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nickname": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "gamesPlayed": { "type": "number" },
        "wins": { "type": "number" },
        "totalWealthPeak": { "type": "number" },
        "totalRentsCollected": { "type": "number" },
        "favoriteCellId": { "type": "number" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "gamesPlayed", "wins", "totalWealthPeak", "totalRentsCollected", "createdAt", "updatedAt"]
    },
    "Friend": {
      "title": "Friend",
      "description": "A user's friend connection",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "friendId": { "type": "string" },
        "nickname": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "addedAt": { "type": "number" }
      },
      "required": ["id", "friendId", "addedAt"]
    }
  },
  "firestore": {
    "/rooms/{roomId}": {
      "schema": { "$ref": "Room" },
      "description": "Game rooms active in the system"
    },
    "/users/{userId}": {
      "schema": { "$ref": "UserProfile" },
      "description": "Player profile and game statistics"
    },
    "/users/{userId}/friends/{friendId}": {
      "schema": { "$ref": "Friend" },
      "description": "A user's friend"
    }
  }
}
