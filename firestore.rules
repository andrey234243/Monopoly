rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidRoom(data) {
       return data.keys().hasAll(['id', 'name', 'hostId', 'gameState', 'createdAt', 'updatedAt']) &&
              data.keys().size() <= 6 &&
              data.id is string && data.id.size() <= 128 &&
              data.name is string && data.name.size() <= 100 &&
              data.hostId is string && data.hostId.size() <= 128 &&
              data.gameState is string && data.gameState.size() <= 1000000 &&
              data.createdAt is int &&
              data.updatedAt is int;
    }

    match /rooms/{roomId} {
      allow read: if isSignedIn(); // We need players to be able to find and load rooms
      
      allow create: if isSignedIn() &&
                    isValidId(roomId) &&
                    isValidRoom(incoming()) &&
                    incoming().id == roomId &&
                    incoming().hostId == request.auth.uid;
                    
      allow update: if isSignedIn() &&
                    isValidId(roomId) &&
                    isValidRoom(incoming()) &&
                    incoming().id == existing().id &&
                    incoming().hostId == existing().hostId &&
                    incoming().createdAt == existing().createdAt;
                    // Let any connected player update the gamestate during their turn
                    // or during trading, so we allow any signed-in user to update the state as long as it conforms to the schema.
                    // This is slightly more permissive but required for P2P-like shared state updates.
    }
    function isValidUserProfile(data) {
       return data.keys().hasAll(['id', 'gamesPlayed', 'wins', 'totalWealthPeak', 'totalRentsCollected', 'createdAt', 'updatedAt']) &&
              data.id is string && data.id.size() <= 128 &&
              data.gamesPlayed is int &&
              data.wins is int &&
              data.totalWealthPeak is int &&
              data.totalRentsCollected is int &&
              data.createdAt is int &&
              data.updatedAt is int &&
              (data.get('nickname', '') is string && data.get('nickname', '').size() <= 100) &&
              (data.get('nicknameLower', '') is string && data.get('nicknameLower', '').size() <= 100) &&
              (data.get('avatarUrl', '') is string && data.get('avatarUrl', '').size() <= 1000);
    }

    function isValidFriend(data) {
        return data.keys().hasAll(['id', 'friendId', 'addedAt']) &&
               data.id is string && data.id.size() <= 128 &&
               data.friendId is string && data.friendId.size() <= 128 &&
               data.addedAt is int &&
               (data.get('nickname', '') is string && data.get('nickname', '').size() <= 100) &&
               (data.get('avatarUrl', '') is string && data.get('avatarUrl', '').size() <= 1000);
    }

    function isValidFriendRequest(data) {
        return data.keys().hasAll(['id', 'requesterId', 'status', 'createdAt']) &&
               data.id is string && data.id.size() <= 128 &&
               data.requesterId is string && data.requesterId.size() <= 128 &&
               data.status == 'pending' &&
               data.createdAt is int &&
               (data.get('nickname', '') is string && data.get('nickname', '').size() <= 100) &&
               (data.get('avatarUrl', '') is string && data.get('avatarUrl', '').size() <= 1000);
    }

    function isValidInvite(data) {
        return data.keys().hasAll(['id', 'roomId', 'hostName', 'createdAt']) &&
               data.id is string && data.id.size() <= 128 &&
               data.roomId is string && data.roomId.size() <= 128 &&
               data.hostName is string && data.hostName.size() <= 100 &&
               data.createdAt is int;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() &&
                    isValidId(userId) &&
                    isValidUserProfile(incoming()) &&
                    incoming().id == request.auth.uid;
      allow update: if isSignedIn() &&
                    isValidId(userId) &&
                    isValidUserProfile(incoming()) &&
                    incoming().id == existing().id &&
                    incoming().id == request.auth.uid &&
                    incoming().createdAt == existing().createdAt;
    }

    match /users/{userId}/friends/{friendId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow list: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() &&
                    isValidId(friendId) &&
                    isValidFriend(incoming()) &&
                    incoming().id == friendId &&
                    incoming().friendId == friendId &&
                    (
                       (request.auth.uid == userId) || 
                       (request.auth.uid == friendId && exists(/databases/$(database)/documents/users/$(request.auth.uid)/friendRequests/$(userId)))
                    );
      allow delete: if isSignedIn() && (request.auth.uid == userId || request.auth.uid == friendId);
    }

    match /users/{userId}/friendRequests/{requesterId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow list: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() &&
                    isValidId(requesterId) &&
                    isValidFriendRequest(incoming()) &&
                    incoming().id == requesterId &&
                    incoming().requesterId == request.auth.uid &&
                    userId != request.auth.uid;
      allow delete: if isSignedIn() && (request.auth.uid == userId || request.auth.uid == requesterId);
    }

    match /users/{userId}/invites/{inviteId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow list: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() &&
                    isValidId(inviteId) &&
                    isValidInvite(incoming()) &&
                    incoming().id == inviteId &&
                    exists(/databases/$(database)/documents/users/$(userId)/friends/$(request.auth.uid));
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
